# 生产环境配置

# API配置 - 生产环境直接连接后端
# 如果后端和前端部署在同一域名,可以使用相对路径: /api
# 如果前后端分离部署,需要填写完整的后端URL: http://your-backend-domain.com
# 注意:不要在URL后面加 /api,因为后端路由本身就是 /api/xxx
VITE_API_BASE_URL=http://your-backend-domain.com
VITE_API_TIMEOUT=30000

# 前端服务器端口 (生产构建后由nginx等服务器控制)
VITE_PORT=80

# 应用配置
VITE_APP_TITLE=AI Novel Platform
VITE_APP_VERSION=1.0.0

# 功能开关
VITE_ENABLE_MOCK=false
VITE_ENABLE_DEBUG=false

# 其他配置
VITE_MAX_FILE_SIZE=10485760
