# AI Novel Platform 前端环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# ============================================
# API配置
# ============================================
# 开发环境使用代理: /api
# 生产环境使用完整URL: http://your-backend.com/api
VITE_API_BASE_URL=/api

# API请求超时时间 (毫秒)
VITE_API_TIMEOUT=60000

# ============================================
# 前端服务器配置
# ============================================
# 开发服务器端口
VITE_PORT=3000

# ============================================
# 应用配置
# ============================================
VITE_APP_TITLE=AI Novel Platform
VITE_APP_VERSION=1.0.0

# ============================================
# 功能开关
# ============================================
# 启用Mock数据 (仅开发环境)
VITE_ENABLE_MOCK=false

# 启用调试模式 (仅开发环境)
VITE_ENABLE_DEBUG=true

# ============================================
# 其他配置
# ============================================
# 最大文件上传大小 (字节, 10MB)
VITE_MAX_FILE_SIZE=10485760
