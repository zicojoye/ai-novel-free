# ============================================
# AI Novel Platform 环境变量配置示例
# ============================================
# ⚠️  重要提示:
# 1. 将此文件复制为 .env 并填写实际配置
# 2. 生产环境必须修改SECRET_KEY (运行: python generate_secret_key.py)
# 3. 必须配置至少一个AI API密钥才能使用AI功能
# 4. .env文件包含敏感信息,请勿提交到版本控制系统
# ============================================

# ============================================
# 应用配置
# ============================================
APP_NAME=AI Novel Platform
APP_VERSION=1.0.0
APP_ENV=development

# ============================================
# 服务器配置
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=sqlite:///./data/ai_novel.db

# ============================================
# AI模型配置
# ============================================
# ⚠️  必须配置至少一个API密钥
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

DEFAULT_MODEL=gpt-4o
DEFAULT_LLM_PROVIDER=openai

# ============================================
# 向量数据库配置 (可选)
# ============================================
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ============================================
# Redis缓存配置 (可选)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# 安全配置
# ============================================
SECRET_KEY=run-python-generate_secret_key.py-to-generate-secure-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================
# 文件存储配置
# ============================================
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE=10485760

# ============================================
# LLM成本优化配置
# ============================================
ENABLE_CACHE=true
CACHE_TTL=3600
ENABLE_SEMANTIC_CACHE=true
SEMANTIC_CACHE_THRESHOLD=0.9
DAILY_BUDGET=10.0
ENABLE_BUDGET_LIMIT=true

# ============================================
# Agent配置
# ============================================
ENABLE_AGENT_TEAM=true
AGENT_TIMEOUT=300
AGENT_MAX_TURNS=10

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./data/logs/app.log

# ============================================
# 请求限流配置
# ============================================
RATE_LIMIT_PER_MINUTE=60

# ============================================
# 安全响应头配置
# ============================================
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline' 'unsafe-eval'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: https:
CSP_CONNECT_SRC='self' http://localhost:8000
